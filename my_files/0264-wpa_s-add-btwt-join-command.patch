From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: woziwrt <https://github.com/woziwrt>
Date: Fri, 29 May 2026 10:00:00 +0200
Subject: [PATCH] wpa_supplicant: add JOIN_BTWT command for broadcast TWT membership

Add wpa_cli command JOIN_BTWT <id> that sends a Broadcast TWT Setup
Request frame (Negotiation Type = Broadcast TWT Membership) to the AP.

For MLO connections, the frame is sent on the 2.4GHz link (freq < 3000 MHz)
where BTWT/R-TWT groups are advertised, not on the primary association link
which may be 5GHz or 6GHz.

Signed-off-by: woziwrt <https://github.com/woziwrt>
---
 wpa_supplicant/ctrl_iface.c       | 16 ++++++++++
 wpa_supplicant/twt.c              | 61 +++++++++++++++++++++++++++++++
 wpa_supplicant/wpa_supplicant_i.h |  1 +
 3 files changed, 78 insertions(+)

--- a/wpa_supplicant/twt.c
+++ b/wpa_supplicant/twt.c
@@ -139,4 +139,76 @@ int wpas_twt_send_teardown(struct wpa_supplicant *wpa_s, u8 flags)
 	return ret;
 }
 
+int wpas_btwt_send_join(struct wpa_supplicant *wpa_s, u8 btwt_id)
+{
+	struct wpabuf *buf;
+	u16 req_type = 0;
+	u16 btwt_info = 0;
+	unsigned int btwt_freq = wpa_s->assoc_freq;
+	int link_id, ret = 0;
+
+	if (wpa_s->wpa_state != WPA_COMPLETED || !wpa_s->current_ssid) {
+		wpa_printf(MSG_DEBUG,
+			   "BTWT: No connection - cannot send BTWT Join frame");
+		return -ENOTCONN;
+	}
+
+	if (btwt_id == 0 || btwt_id > 31) {
+		wpa_printf(MSG_DEBUG, "BTWT: Invalid BTWT ID %u (must be 1-31)",
+			   btwt_id);
+		return -EINVAL;
+	}
+
+	/* For MLO: BTWT/R-TWT is advertised on the 2.4GHz link (freq < 3000).
+	 * Send the TWT Setup frame on that link, not on the primary assoc link
+	 * which may be 5GHz or 6GHz and would cause the frame to be dropped. */
+	if (wpa_s->valid_links) {
+		for (link_id = 0; link_id < MAX_NUM_MLD_LINKS; link_id++) {
+			if (!(wpa_s->valid_links & BIT(link_id)))
+				continue;
+			if (wpa_s->links[link_id].freq > 0 &&
+			    wpa_s->links[link_id].freq < 3000) {
+				btwt_freq = wpa_s->links[link_id].freq;
+				wpa_printf(MSG_DEBUG,
+					   "BTWT: Using link %d (freq=%u) for join",
+					   link_id, btwt_freq);
+				break;
+			}
+		}
+	}
+
+	buf = wpabuf_alloc(3 + 19);
+	if (!buf)
+		return -ENOMEM;
+
+	wpa_printf(MSG_DEBUG, "BTWT: Sending Join Request for BTWT ID %u on freq=%u",
+		   btwt_id, btwt_freq);
+
+	wpabuf_put_u8(buf, WLAN_ACTION_S1G);
+	wpabuf_put_u8(buf, S1G_ACT_TWT_SETUP);
+	wpabuf_put_u8(buf, 1);
+	wpabuf_put_u8(buf, WLAN_EID_TWT);
+	wpabuf_put_u8(buf, 17);
+	wpabuf_put_u8(buf, 0x1C);
+	req_type = BIT(0) | BIT(5) | BIT(6);
+	req_type |= (btwt_id & 0x7) << 7;
+	wpabuf_put_le16(buf, req_type);
+	wpabuf_put_le64(buf, 0);
+	wpabuf_put_u8(buf, 0);
+	wpabuf_put_le16(buf, 0);
+	wpabuf_put_u8(buf, 0);
+	btwt_info = (btwt_id & 0x1F) << 3;
+	wpabuf_put_le16(buf, btwt_info);
+
+	if (wpa_drv_send_action(wpa_s, btwt_freq, 0, wpa_s->bssid,
+				wpa_s->own_addr, wpa_s->bssid,
+				wpabuf_head(buf), wpabuf_len(buf), 0) < 0) {
+		wpa_printf(MSG_DEBUG, "BTWT: Failed to send Join Request");
+		ret = -ECANCELED;
+	}
+
+	wpabuf_free(buf);
+	return ret;
+}
+
 #endif /* CONFIG_TESTING_OPTIONS */
--- a/wpa_supplicant/wpa_supplicant_i.h
+++ b/wpa_supplicant/wpa_supplicant_i.h
@@ -1838,4 +1838,5 @@ int wpas_twt_send_setup(struct wpa_supplicant *wpa_s, u8 dtok, int exponent,
 			u8 twt_channel, u8 control);
 int wpas_twt_send_teardown(struct wpa_supplicant *wpa_s, u8 flags);
+int wpas_btwt_send_join(struct wpa_supplicant *wpa_s, u8 btwt_id);
 
 void wpas_rrm_reset(struct wpa_supplicant *wpa_s);
--- a/wpa_supplicant/ctrl_iface.c
+++ b/wpa_supplicant/ctrl_iface.c
@@ -10708,4 +10708,16 @@ static int wpas_ctrl_iface_send_twt_teardown(struct wpa_supplicant *wpa_s,
 	return wpas_twt_send_teardown(wpa_s, flags);
 }
 
+static int wpas_ctrl_iface_btwt_join(struct wpa_supplicant *wpa_s,
+				     const char *cmd)
+{
+	u8 btwt_id = (u8)atoi(cmd);
+
+	if (btwt_id == 0 || btwt_id > 31) {
+		wpa_printf(MSG_DEBUG, "JOIN_BTWT: invalid id %u", btwt_id);
+		return -1;
+	}
+	return wpas_btwt_send_join(wpa_s, btwt_id);
+}
+
 #endif /* CONFIG_TESTING_OPTIONS */
@@ -14156,4 +14156,7 @@ static int wpa_supplicant_ctrl_iface_process(struct ctrl_iface_priv *priv,
 	} else if (os_strcmp(buf, "TWT_TEARDOWN") == 0) {
 		if (wpas_ctrl_iface_send_twt_teardown(wpa_s, ""))
 			reply_len = -1;
+	} else if (os_strncmp(buf, "JOIN_BTWT ", 10) == 0) {
+		if (wpas_ctrl_iface_btwt_join(wpa_s, buf + 10))
+			reply_len = -1;
 	} else if (os_strncmp(buf, "ML_PROBE_REQ ", 13) == 0) {
