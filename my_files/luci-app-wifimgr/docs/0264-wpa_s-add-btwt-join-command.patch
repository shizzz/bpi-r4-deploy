From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: woziwrt <https://github.com/woziwrt>
Date: Fri, 29 May 2026 10:00:00 +0200
Subject: [PATCH] wpa_supplicant: add JOIN_BTWT command for broadcast TWT membership

Add wpa_cli command JOIN_BTWT <id> that sends a Broadcast TWT Setup
Request frame (Negotiation Type = Broadcast TWT Membership) to the AP,
allowing the STA to formally join an existing Broadcast TWT / R-TWT group
previously established by the AP via add_btwt/recommendation=4.

Frame structure:
  Control = 0x1C: Negotiation Type=0b11 (Broadcast TWT Membership) | TWT Info disabled
  BTWT Info field (2 bytes): BTWT ID in bits 3-7

Enables R-TWT + Neg-TTLM combination where:
  - AP creates R-TWT groups with per-TID time reservation (recommendation=4)
  - AP applies Neg-TTLM to steer TID traffic to specific links
  - STA joins R-TWT groups to get guaranteed time slots per traffic class

Signed-off-by: woziwrt <https://github.com/woziwrt>
---
 wpa_supplicant/ctrl_iface.c      | 16 ++++++++++
 wpa_supplicant/twt.c             | 52 ++++++++++++++++++++++++++++++++
 wpa_supplicant/wpa_supplicant_i.h |  1 +
 3 files changed, 69 insertions(+)

diff --git a/wpa_supplicant/twt.c b/wpa_supplicant/twt.c
--- a/wpa_supplicant/twt.c
+++ b/wpa_supplicant/twt.c
@@ -139,4 +139,56 @@ int wpas_twt_send_teardown(struct wpa_supplicant *wpa_s, u8 flags)
 	return ret;
 }
 
+/**
+ * wpas_btwt_send_join - Send BTWT Join Request to join a Broadcast TWT group
+ * @wpa_s: Pointer to wpa_supplicant
+ * @btwt_id: Broadcast TWT ID to join (1-31)
+ *
+ * Sends TWT Setup Action frame with Negotiation Type = Broadcast TWT
+ * Membership (0b11) to join an existing BTWT/R-TWT group on the AP.
+ * Used to formally subscribe to R-TWT groups created with recommendation=4.
+ *
+ * Returns: 0 on success, negative error code otherwise
+ */
+int wpas_btwt_send_join(struct wpa_supplicant *wpa_s, u8 btwt_id)
+{
+	struct wpabuf *buf;
+	u16 req_type = 0;
+	u16 btwt_info = 0;
+	int ret = 0;
+
+	if (wpa_s->wpa_state != WPA_COMPLETED || !wpa_s->current_ssid) {
+		wpa_printf(MSG_DEBUG,
+			   "BTWT: No connection - cannot send BTWT Join frame");
+		return -ENOTCONN;
+	}
+
+	if (btwt_id == 0 || btwt_id > 31) {
+		wpa_printf(MSG_DEBUG, "BTWT: Invalid BTWT ID %u (must be 1-31)",
+			   btwt_id);
+		return -EINVAL;
+	}
+
+	/* 3 = Action cat + Action code + Dialog token */
+	/* 19 = EID(1) + len(1) + control(1) + req_type(2) + twt(8) + dur(1) + mantissa(2) + channel(1) + btwt_info(2) */
+	buf = wpabuf_alloc(3 + 19);
+	if (!buf)
+		return -ENOMEM;
+
+	wpa_printf(MSG_DEBUG, "BTWT: Sending Join Request for BTWT ID %u",
+		   btwt_id);
+
+	wpabuf_put_u8(buf, WLAN_ACTION_S1G);
+	wpabuf_put_u8(buf, S1G_ACT_TWT_SETUP);
+	wpabuf_put_u8(buf, 1); /* dialog token */
+
+	wpabuf_put_u8(buf, WLAN_EID_TWT);
+	wpabuf_put_u8(buf, 17); /* TWT element payload length */
+
+	/* Control: bits 2-3 = 0b11 = Broadcast TWT Membership
+	 * bit 4 = TWT Information Frame Disabled
+	 * = 0x0C | 0x10 = 0x1C */
+	wpabuf_put_u8(buf, 0x1C);
+
+	/* Request Type:
+	 * bit 0   = 1: TWT Request (STA is requesting)
+	 * bits 1-3 = 0: Setup Command = Request
+	 * bit 5   = 1: Implicit TWT
+	 * bit 6   = 1: Flow Type = Unannounced
+	 * bits 7-9 = btwt_id & 0x7 (low 3 bits in BTWT Recommendation field) */
+	req_type = BIT(0) | BIT(5) | BIT(6);
+	req_type |= (btwt_id & 0x7) << 7;
+	wpabuf_put_le16(buf, req_type);
+
+	wpabuf_put_le64(buf, 0); /* TWT target time: 0 = use AP schedule */
+	wpabuf_put_u8(buf, 0);   /* Min TWT Wake Duration: 0 = use AP value */
+	wpabuf_put_le16(buf, 0); /* TWT Wake Interval Mantissa: 0 = use AP */
+	wpabuf_put_u8(buf, 0);   /* TWT Channel */
+
+	/* BTWT Info field (2 bytes):
+	 * bits 3-7 = BTWT ID (which group we want to join)
+	 * bits 8-15 = Persistence (0 = use existing group persistence) */
+	btwt_info = (btwt_id & 0x1F) << 3;
+	wpabuf_put_le16(buf, btwt_info);
+
+	if (wpa_drv_send_action(wpa_s, wpa_s->assoc_freq, 0, wpa_s->bssid,
+				wpa_s->own_addr, wpa_s->bssid,
+				wpabuf_head(buf), wpabuf_len(buf), 0) < 0) {
+		wpa_printf(MSG_DEBUG, "BTWT: Failed to send Join Request");
+		ret = -ECANCELED;
+	}
+
+	wpabuf_free(buf);
+	return ret;
+}
+
 #endif /* CONFIG_TESTING_OPTIONS */
diff --git a/wpa_supplicant/wpa_supplicant_i.h b/wpa_supplicant/wpa_supplicant_i.h
--- a/wpa_supplicant/wpa_supplicant_i.h
+++ b/wpa_supplicant/wpa_supplicant_i.h
@@ -1838,6 +1838,7 @@ int wpas_twt_send_setup(struct wpa_supplicant *wpa_s, u8 dtok, int exponent,
 			u8 twt_channel, u8 control);
 int wpas_twt_send_teardown(struct wpa_supplicant *wpa_s, u8 flags);
+int wpas_btwt_send_join(struct wpa_supplicant *wpa_s, u8 btwt_id);
 
 void wpas_rrm_reset(struct wpa_supplicant *wpa_s);
diff --git a/wpa_supplicant/ctrl_iface.c b/wpa_supplicant/ctrl_iface.c
--- a/wpa_supplicant/ctrl_iface.c
+++ b/wpa_supplicant/ctrl_iface.c
@@ -10708,6 +10708,18 @@ static int wpas_ctrl_iface_send_twt_teardown(struct wpa_supplicant *wpa_s,
 	return wpas_twt_send_teardown(wpa_s, flags);
 }
 
+static int wpas_ctrl_iface_btwt_join(struct wpa_supplicant *wpa_s,
+				     const char *cmd)
+{
+	u8 btwt_id = (u8)atoi(cmd);
+
+	if (btwt_id == 0 || btwt_id > 31) {
+		wpa_printf(MSG_DEBUG, "JOIN_BTWT: invalid id %u", btwt_id);
+		return -1;
+	}
+	return wpas_btwt_send_join(wpa_s, btwt_id);
+}
+
 #endif /* CONFIG_TESTING_OPTIONS */
@@ -14156,6 +14156,10 @@ static int wpa_supplicant_ctrl_iface_process(struct ctrl_iface_priv *priv,
 	} else if (os_strcmp(buf, "TWT_TEARDOWN") == 0) {
 		if (wpas_ctrl_iface_send_twt_teardown(wpa_s, ""))
 			reply_len = -1;
+	} else if (os_strncmp(buf, "JOIN_BTWT ", 10) == 0) {
+		if (wpas_ctrl_iface_btwt_join(wpa_s, buf + 10))
+			reply_len = -1;
 	} else if (os_strncmp(buf, "ML_PROBE_REQ ", 13) == 0) {
